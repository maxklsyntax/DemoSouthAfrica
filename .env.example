# SAP Digital Manufacturing
SAP_DM_CLIENT_ID=your-client-id
SAP_DM_CLIENT_SECRET=your-client-secret
SAP_DM_TOKEN_URL=https://your-subdomain.authentication.eu20.hana.ondemand.com/oauth/token
SAP_DM_BASE_URL=https://api.test.eu20.dmc.cloud.sap
SAP_DM_PLANT=1070
SAP_DM_RESOURCE=your-resource-name
SAP_DM_LABEL_PROCESS_KEY=REG_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# SAP_DM_WEIGHT_PROCESS_KEY=REG_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SAP Asset Performance Management
SAP_APM_AUTH_MODE=apikey
SAP_APM_API_KEY=your-api-key
SAP_APM_BASE_URL=https://api.your-subdomain.cfapps.eu10.hana.ondemand.com
SAP_APM_CLIENT_ID=
SAP_APM_CLIENT_SECRET=
SAP_APM_TOKEN_URL=
SAP_APM_EQUIPMENT_ID=EQUIP_001

# General
LOG_LEVEL=INFO
WEB_HOST=0.0.0.0
WEB_PORT=8080
